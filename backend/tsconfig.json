{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": false,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,

    "useDefineForClassFields": false
  }
}